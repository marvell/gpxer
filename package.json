{
  "name": "gpxer",
  "version": "0.1.0",
  "description": "Free online GPX route splitter for cyclists, hikers, runners, and outdoor route planners.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/marvell/gpxer.git"
  },
  "keywords": [
    "gpx",
    "gpx-splitter",
    "gpx-editor",
    "gpx-viewer",
    "route",
    "route-planner",
    "cycling",
    "hiking",
    "running",
    "outdoor",
    "maplibre",
    "tracks",
    "elevation-profile"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@posthog/react": "^1.10.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1",
    "maplibre-gl": "^5.24.0",
    "posthog-js": "^1.379.1",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "linkedom": "^0.18.12",
    "tailwindcss": "^4.1.11"
  },
  "module": "src/index.ts",
  "peerDependencies": {
    "typescript": "^5"
  }
}
